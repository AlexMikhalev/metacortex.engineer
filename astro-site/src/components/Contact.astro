---
import social from '../data/social.json';
---
<section id="contact" class="contact">
  <h2 class="section-title">Connect</h2>
  <div class="contact-content">
    <div class="contact-info">
      <p style="margin-bottom: 1rem;">
        Interested in collaborating on the convergence of AI, ethics, and systems engineering?
        Let's discuss how we can build the future of intelligent systems together.
      </p>
      <div class="contact-item">
        <span>LinkedIn: <a href={social.linkedin} target="_blank" rel="noopener noreferrer">linkedin.com/in/alexmikhalev</a></span>
      </div>
      <div class="contact-item">
        <span>GitHub: <a href={social.github} target="_blank" rel="noopener noreferrer">github.com/AlexMikhalev</a></span>
      </div>
      <div class="contact-item">
        <span>Website: <a href={social.website} target="_blank" rel="noopener noreferrer">metacortex.engineer</a></span>
      </div>
      <div class="contact-item">
        <span>Blog: <a href={social.blog} target="_blank" rel="noopener noreferrer">sci-blog.com</a></span>
      </div>
    </div>
    <div>
      <p style="margin-bottom: 1rem;">
        <strong>Areas of Interest:</strong>
      </p>
      <p>
        Natural Language Processing, Knowledge Graphs, VR/AR Interfaces,
        Data Privacy, Synthetic Data, Distributed Systems, AI Ethics,
        Healthcare AI, Biotech Applications, Enterprise Architecture
      </p>
      <p style="margin-top: 1rem;">
        "Meta needs Brain -- Cortex: combining AI, ethics, systems and enterprise engineering
        to solve real-world complexity."
      </p>
    </div>
  </div>
</section>
